# Copy to .env at the repo root. Docker Compose picks these up automatically.
# Production deployments MUST override the defaults below.

# --- Backend ------------------------------------------------------------

# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# JWT token lifetime in seconds. Default: 43200 (12h).
JWT_EXPIRES_IN=43200

# bcrypt cost factor. 10 is minimum acceptable; increase for stronger hashes.
BCRYPT_ROUNDS=10

# Base64-encoded 32-byte AES-256 key used for application-level field encryption.
# Generate with: openssl rand -base64 32
# Rotate by re-encrypting all ciphertexts with a new key and updating this value.
CLINICOPS_AES_KEY=

# MongoDB URI. Leave blank to use the built-in in-memory repository (tests / offline).
# Example: mongodb://mongo:27017/clinicops
MONGO_URI=

# Flip to 'true' only when a WeChat integration endpoint is wired up. The
# adapter stays disabled otherwise, and login routes return a 403 on attempt.
WECHAT_OAUTH_ENABLED=false

# Express port. Docker compose maps it to the same host port.
PORT=4000
